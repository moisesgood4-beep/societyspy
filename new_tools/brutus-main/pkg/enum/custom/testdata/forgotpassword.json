{
  "version": "1",
  "oracle": {
    "name": "forgotpassword",
    "request": {
      "method": "POST",
      "url": "https://example.com/forgotpassword",
      "headers": {
        "Content-Type": "application/json"
      },
      "body": "{\"username\":\"{{username}}\"}",
      "body_encoding": "json"
    },
    "match": {
      "rules": [
        {
          "when": {
            "status": 200,
            "body_contains": "reset link sent"
          },
          "verdict": "exists",
          "confidence": "high"
        },
        {
          "when": {
            "status": 404
          },
          "verdict": "absent",
          "confidence": "high"
        },
        {
          "when": {
            "body_regex": "(?i)user not found"
          },
          "verdict": "absent",
          "confidence": "medium"
        }
      ],
      "default": "error"
    }
  }
}
